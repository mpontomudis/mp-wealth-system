# ─── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Edge Function Secrets (set via: supabase secrets set KEY=value) ──
# Anthropic Claude API key for AI transaction parsing
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret for MT5 EA → ingest-metrics and update-exchange-rate
INGEST_API_KEY=your-random-secret-here

# WhatsApp webhook verification token (any string you choose)
WHATSAPP_VERIFY_TOKEN=your-verify-token

# Owner's WhatsApp number in international format (no + prefix)
OWNER_PHONE_NUMBER=628123456789
